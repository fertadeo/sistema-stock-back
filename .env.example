# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=soderia
# Máximo de conexiones simultáneas del backend (default: 5 dev, 10 prod)
DB_POOL_SIZE=5

# JWT
JWT_SECRET=

# =============================================================================
# GOOGLE MAPS — BACKEND (clave privada del servidor)
# =============================================================================
# Consola: https://console.cloud.google.com/google/maps-apis/credentials
#
# 1. Mismo proyecto de Google Cloud que el frontend.
# 2. Habilitar APIs:
#    - Geocoding API
#    - Directions API
# 3. Crear API key separada → Restricción "Direcciones IP" (IP del servidor)
#    o "Ninguna" solo en desarrollo local.
# 4. Pegar en .env.development (dev) o variables del servidor (prod).
# 5. Reiniciar el backend.
#
GOOGLE_MAPS_API_KEY=
