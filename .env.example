# Entorno (development | production)
NODE_ENV=development

# Base de datos — nombres genéricos (recomendado) o con sufijo _DEV / _PROD
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=soderia

# Alternativa con sufijo (solo desarrollo):
# DB_HOST_DEV=localhost
# DB_USER_DEV=root
# DB_PASSWORD_DEV=
# DB_NAME_DEV=soderia
# Máximo de conexiones simultáneas del backend (default: 5 dev, 10 prod)
DB_POOL_SIZE=5

# JWT
JWT_SECRET=

# CORS — origen del frontend (opcional si usas el default de producción)
FRONTEND_URL=https://sistema.soderiadonjavier.com
# Múltiples orígenes separados por coma:
# CORS_ORIGINS=https://sistema.soderiadonjavier.com,http://localhost:3000

# =============================================================================
# GOOGLE MAPS — BACKEND (clave privada del servidor)
# =============================================================================
# Consola: https://console.cloud.google.com/google/maps-apis/credentials
#
# 1. Mismo proyecto de Google Cloud que el frontend.
# 2. Habilitar APIs:
#    - Geocoding API
#    - Directions API
# 3. Crear API key separada → Restricción "Direcciones IP" (IP del servidor)
#    o "Ninguna" solo en desarrollo local.
# 4. Pegar en .env.development (dev) o variables del servidor (prod).
# 5. Reiniciar el backend.
#
GOOGLE_MAPS_API_KEY=

# Web Push — alertas en el celular del repartidor (PWA Android). NO envía correos.
# Generar claves: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Identificador del emisor (protocolo Web Push). URL del sitio o mailto:contacto@...
VAPID_SUBJECT=https://sistema.soderiadonjavier.com
